{
  "name": "@paretoproof/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "bunx tsc -p tsconfig.json",
    "materialize:problem9-package": "tsx src/index.ts materialize-problem9-package",
    "materialize:problem9-prompt-package": "tsx src/index.ts materialize-problem9-prompt-package",
    "materialize:problem9-run-bundle": "tsx src/index.ts materialize-problem9-run-bundle",
    "test:attempt-smoke": "node --import tsx --test --test-reporter=spec test/problem9-attempt-smoke.test.ts",
    "test:cli-contract": "bun --cwd ../../packages/shared build && node --import tsx --test test/worker-cli-contract.test.ts",
    "test:cli-smoke": "node --import tsx --test test/worker-cli-smoke.test.ts",
    "test:run-bundle": "node --import tsx --test src/lib/problem9-run-bundle.test.ts",
    "test:verifier-smoke": "node --import tsx --test --test-reporter=spec test/problem9-verifier-smoke.test.ts",
    "run:problem9-attempt": "tsx src/index.ts run-problem9-attempt",
    "ingest:problem9-run-bundle": "tsx src/index.ts ingest-problem9-run-bundle",
    "run:worker-claim-loop": "tsx src/index.ts run-worker-claim-loop",
    "run:problem9-attempt:trusted-local": "tsx src/index.ts run-problem9-attempt-in-devbox",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@paretoproof/shared": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
