{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tomodovodoo/ParetoProof/schemas/benchmark-item.schema.json",
  "title": "ParetoProof Benchmark Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "track",
    "title",
    "source",
    "lean",
    "artifacts",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "track": {
      "type": "string",
      "enum": [
        "formalize",
        "prove",
        "repair",
        "full_stack"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "citation",
        "license"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "paper",
            "competition",
            "textbook",
            "synthetic",
            "community"
          ]
        },
        "citation": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string"
        }
      }
    },
    "lean": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolchain",
        "imports",
        "statement"
      ],
      "properties": {
        "toolchain": {
          "type": "string"
        },
        "mathlib_commit": {
          "type": "string"
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "theorem_name": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expects_statement_only",
        "expects_proof",
        "adjudication_notes"
      ],
      "properties": {
        "expects_statement_only": {
          "type": "boolean"
        },
        "expects_proof": {
          "type": "boolean"
        },
        "adjudication_notes": {
          "type": "string"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
